# tailor-resume — environment configuration
# Copy to .env and fill in the values you need.
# The core pipeline (profile_extractor, jd_gap_analyzer, latex_renderer) runs on stdlib only.
# The variables below unlock optional cloud features in rag_store.py.

# ── Pinecone (cloud RAG backend) ──────────────────────────────────────────────
# Get a free API key at https://www.pinecone.io
# Without this, rag_store.py falls back to local SQLite (~/.tailor_resume/profiles.db).
# PINECONE_API_KEY=pc-xxxxxxxxxxxxxxxxxxxx
# PINECONE_INDEX=tailor-resume

# ── OpenAI (semantic embeddings) ──────────────────────────────────────────────
# Used by rag_store.py for text-embedding-3-small.
# Without this, rag_store.py falls back to TF-IDF similarity (no API key required).
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
